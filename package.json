{
  "name": "ask-llm",
  "displayName": "Ask LLM",
  "version": "0.0.1",
  "description": "Compressive LLM extension tool",
  "author": "Plasmo Corp. <foss@plasmo.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "web:dev": "npm --prefix apps/website run dev",
    "web:build": "npm --prefix apps/website run build",
    "web:preview": "npm --prefix apps/website run preview"
  },
  "dependencies": {
    "@plasmohq/messaging": "^0.7.2",
    "@plasmohq/storage": "github:plasmohq/storage",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*",
      "http://localhost/*"
    ],
    "permissions": [
      "activeTab",
      "scripting",
      "storage"
    ]
  }
}
